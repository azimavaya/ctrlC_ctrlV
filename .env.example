# Environment variable template for Panther Cloud Air.
# Copy to .env and fill in real values before running in production.
# NEVER commit .env to version control.

# Database
DB_ROOT_PASSWORD=change-me-root
DB_NAME=pca_db
DB_USER=pca_user
DB_PASSWORD=change-me-db-password

# Flask backend
FLASK_ENV=production

# JWT secret: generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-jwt-secret

# Admin user password (set before first run; admin account is seeded on startup)
ADMIN_PASSWORD=change-me-admin-password

# CORS: set to the URL your frontend is served from (no trailing slash)
CORS_ORIGINS=http://localhost:3000
